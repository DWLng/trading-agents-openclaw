# TradingAgents OpenClaw 环境变量配置
# 复制此文件为 .env 并填入你的实际密钥

# ============================================
# 东方财富妙想 API Key（必须）
# 获取地址：https://dl.dfcfs.com/m/itc4
# ============================================
export MX_APIKEY="your_mx_apikey_here"

# ============================================
# MiniMax API Key（TradingAgents LLM 驱动）
# ============================================
export MINIMAX_API_KEY="your_minimax_key_here"

# ============================================
# 可选配置
# ============================================

# TradingAgents 项目路径（如果不使用默认的 ~/TradingAgents-Kimi）
# export TRADINGAGENTS_PROJECT="$HOME/TradingAgents-Kimi"

# MX Skills 输出目录（默认：~/.openclaw/workspace/mx_data/output）
# export MX_OUTPUT_DIR="$HOME/mx_data/output"
