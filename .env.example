# TradingAgents OpenClaw 环境变量配置
# 复制此文件为 .env 并填入实际值

# ===========================================
# API Keys (必需)
# ===========================================

# MiniMax API Key (TradingAgents LLM驱动)
MINIMAX_API_KEY=your_minimax_api_key_here

# DeepSeek API Key (可选，用于额外模型支持)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ===========================================
# 东方财富妙想 MX API (必需)
# ===========================================

# 东方财富妙想 API Key
MX_APIKEY=your_mx_apikey_here

# ===========================================
# 阿里云 OSS (可选，用于HTML报告托管)
# 如使用Cloudflare Pages可忽略以下配置
# ===========================================

OSS_ACCESS_KEY_ID=your_oss_access_key_id
OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_DEFAULT_BUCKET=trading-agent-reports

# ===========================================
# Cloudflare Pages (可选，用于HTML报告托管)
# ===========================================

# Wrangler认证token
# 从 https://dash.cloudflare.com/profile/api-tokens 获取
CF_API_TOKEN=your_cf_api_token_here

# ===========================================
# 飞书配置 (必需)
# ===========================================

# 飞书应用 App ID 和 App Secret
# 从 https://open.feishu.cn/ 获取
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret

# 如需多账号配置
DESKTOP_FEISHU_APP_ID=your_desktop_feishu_app_id
DESKTOP_FEISHU_APP_SECRET=your_desktop_feishu_app_secret
TRADING_FEISHU_APP_ID=your_trading_feishu_app_id
TRADING_FEISHU_APP_SECRET=your_trading_feishu_app_secret

# ===========================================
# OpenClaw Gateway (可选)
# ===========================================

# Gateway认证token
GATEWAY_TOKEN=your_gateway_token_here

# ===========================================
# 可选配置
# ===========================================

# TradingAgents 项目路径（如果不使用默认的 ~/TradingAgents-Kimi）
# TRADINGAGENTS_PROJECT="$HOME/TradingAgents-Kimi"

# MX Skills 输出目录（默认：~/.openclaw/workspace/mx_data/output）
# MX_OUTPUT_DIR="$HOME/mx_data/output"
